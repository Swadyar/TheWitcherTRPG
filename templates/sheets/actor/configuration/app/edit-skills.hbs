<div class="edit-stats">
    {{#with (lookup system.skills skillKey) as |skillGroup|}}
        {{#each skillGroup as |skill skillName|}}
            <details>
                <summary style="display: flex; gap: 10px;">
                    <span>{{localize skill.label}} <input class='header-stat stat-max'
                            name='system.skills.{{@root.skillKey}}.{{skillName}}.value' type='number'
                            value='{{skill.value}}' placeholder='0' data-dtype='Number' /></span>
                    <button data-action="level-up"
                        data-skill="{{skillName}}">{{localize "WITCHER.skills.levelUp"}}</button>
                </summary>
                <div>

                    <label>{{localize "WITCHER.skills.profession"}}:
                        <input class="skill-checkbox" type="checkbox"
                            name="system.skills.{{@root.skillKey}}.{{skillName}}.isProfession"
                            {{checked skill.isProfession}} />
                    </label>
                    <label>{{localize "WITCHER.skills.pickup"}}:
                        <input class="skill-checkbox" type="checkbox"
                            name="system.skills.{{@root.skillKey}}.{{skillName}}.isPickup" {{checked skill.isPickup}} />
                    </label>
                    <label>{{localize "WITCHER.skills.learn"}}:
                        <input class="skill-checkbox" type="checkbox"
                            name="system.skills.{{@root.skillKey}}.{{skillName}}.isLearned"
                            {{checked skill.isLearned}} />
                    </label>
                </div>
                <div class='skill-modifiers'>
                    {{#if skill.activeEffectModifiers}}
                        <tr>
                            <td colspan="3">
                                <div class="list-modifiers">
                                    <input class="medium skill-mod-edit" type="text"
                                        value="{{localize "WITCHER.activeEffect.tab"}}" disabled />
                                    <input class="small skill-mod-edit" type="number"
                                        value="{{skill.activeEffectModifiers}}" disabled />
                                </div>
                            </td>
                        </tr>
                    {{/if}}
                </div>

            </details>
        {{/each}}
    {{/with}}
</div>